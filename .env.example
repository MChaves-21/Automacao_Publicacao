# ─── Painel Web ────────────────────────────────────────────
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria-longa
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sua-senha-aqui
ADMIN_EMAIL=admin@seudominio.com
APP_URL=https://seu-app.onrender.com

# ─── IA ────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...          # https://aistudio.google.com/app/apikey (gratuito)
OPENAI_API_KEY=sk-...           # https://platform.openai.com (DALL-E 3)

# ─── Banco de dados ────────────────────────────────────────
DATABASE_URL=postgres://...     # Aiven ou Supabase

# ─── Slack ─────────────────────────────────────────────────
# Criar em: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Upload de imagens ─────────────────────────────────────
# Cloudinary (opcional) — sem isso usa armazenamento local
# https://cloudinary.com (free tier: 25GB)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── E-mail SMTP ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # Senha de app do Google
SMTP_FROM=MktAuto <seu@gmail.com>

# ─── YouTube OAuth ─────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://seu-app.onrender.com/youtube/callback

# ─── Twitter / X ───────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# ─── Instagram / Facebook ──────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ─── LinkedIn ──────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ─── TikTok ────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ─── Pinterest ─────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# ─── WhatsApp Business ─────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_RECIPIENT=

# ─── Google My Business ────────────────────────────────────
GOOGLE_ACCESS_TOKEN=
GMB_LOCATION_NAME=

# ─── Rate Limiting (Redis opcional, padrão: memória) ───────
# RATELIMIT_STORAGE_URL=redis://localhost:6379
